{
    "name": "@evolv-delivery/upgrade-eligibility",
    "version": "0.0.17",
    "description": "Creates an audience for CPC lines that are eligible for upgrade",
    "main": "dist/index.js",
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "clear": "rm -rf dist",
        "build": "npm run clear && rollup --config rollup.config.js",
        "watch": "rollup --config rollup.config.js --watch",
        "serve": "http-server ./dist/es/ --cors --silent",
        "dev": "npm-run-all -s clear -p watch serve",
        "start": "npm run dev",
        "publish": "npm run build && npm publish",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "author": "charles-evolv",
    "repository": {
        "type": "git",
        "url": "https://github.com/evolv-ai/env-integrations.git"
    },
    "homepage": "https://github.com/evolv-ai/env-integrations/",
    "bugs": {
        "url": "https://github.com/evolv-ai/env-integrations/issues"
    },
    "devDependencies": {
        "@rollup/plugin-json": "^4.1.0",
        "http-server": "^14.1.1",
        "npm-run-all": "^4.1.5",
        "rollup-plugin-commonjs": "^10.1.0",
        "rollup-plugin-node-resolve": "^5.2.0"
    },
    "license": "ISC"
}
